{
 "compilerOptions": {
  "lib": [
   "es7",
   "dom"
  ],
  "module": "commonjs",
  "moduleResolution": "node",
  "noImplicitReturns": true,
  "outDir": "lib",
  "sourceMap": true,
  "target": "es6",
  "allowJs": true,
  "allowSyntheticDefaultImports": true,
  "skipLibCheck": true,
  "types": [
   "node"
  ]
 },
 "compileOnSave": true,
 "include": [
  "src"
 ]
}
